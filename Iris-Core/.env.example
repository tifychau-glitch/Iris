# IRIS Core -- Environment Variables
# Copy this file to .env and fill in your values

# Anthropic API key (from console.anthropic.com)
ANTHROPIC_API_KEY=

# Anthropic model (default: claude-sonnet-4-20250514)
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Telegram bot token (from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=

# Telegram bot username (without @)
BOT_USERNAME=IrisAccountabilityBot

# Web signup form port
WEB_PORT=8080

# Pro upgrade URL
PRO_UPGRADE_URL=https://iris-ai.co

# Email delivery (Gmail SMTP)
# Create an app password at myaccount.google.com/apppasswords
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=
