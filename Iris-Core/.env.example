# IRIS Core -- Environment Variables
# Copy this file to .env and fill in your values

# Anthropic API key (from console.anthropic.com)
ANTHROPIC_API_KEY=

# Anthropic model (default: claude-sonnet-4-20250514)
# Use sonnet for cost efficiency on the free tier
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Telegram bot token (from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=

# Telegram bot username (without @)
BOT_USERNAME=IrisAccountabilityBot

# Web signup form port
WEB_PORT=8080

# Pro upsell URL
PRO_URL=https://iris-ai.co
