{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "iris-core-state-schema",
  "title": "IRIS Core State",
  "description": "Schema for memory/core-state.json — canonical machine-readable facts about the user and business.",
  "type": "object",
  "required": ["_meta", "identity", "current_goals", "offer_stack", "tone_preferences", "active_commitments", "active_project_context", "canonical_business_facts"],
  "additionalProperties": false,
  "properties": {
    "_meta": {
      "type": "object",
      "required": ["version", "last_updated_at", "last_confirmed_at", "source_of_last_write", "audit_log_ref"],
      "additionalProperties": true,
      "properties": {
        "version": {
          "type": "integer",
          "minimum": 1,
          "description": "Incremented on every write. Never reset."
        },
        "last_updated_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of last write."
        },
        "last_confirmed_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of last user_explicit or user_confirmed write."
        },
        "source_of_last_write": {
          "type": "string",
          "enum": ["user_explicit", "user_confirmed", "system_canonical"],
          "description": "Source of the most recent write."
        },
        "audit_log_ref": {
          "type": "string",
          "description": "Path to the audit log file."
        }
      }
    },
    "identity": {
      "type": "object",
      "required": ["name", "role", "business_name", "business_type"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "role": { "type": "string", "minLength": 1 },
        "business_name": { "type": "string", "description": "Empty string is valid — user has not named the business yet." },
        "business_type": { "type": "string", "minLength": 1 }
      }
    },
    "current_goals": {
      "type": "object",
      "required": ["primary", "secondary", "horizon", "last_stated_at"],
      "additionalProperties": false,
      "properties": {
        "primary": { "type": "string", "minLength": 1 },
        "secondary": {
          "type": "array",
          "items": { "type": "string" }
        },
        "horizon": {
          "type": "string",
          "enum": ["short", "medium", "long"]
        },
        "last_stated_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "offer_stack": {
      "type": "object",
      "required": ["products", "pricing_last_confirmed_at"],
      "additionalProperties": false,
      "properties": {
        "products": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "price", "description", "status"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "price": { "type": "string", "minLength": 1 },
              "description": { "type": "string" },
              "status": {
                "type": "string",
                "enum": ["active", "paused", "deprecated"]
              }
            }
          }
        },
        "pricing_last_confirmed_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "tone_preferences": {
      "type": "object",
      "required": ["communication_style", "writing_voice", "avoid"],
      "additionalProperties": false,
      "properties": {
        "communication_style": { "type": "string", "minLength": 1 },
        "writing_voice": { "type": "string", "minLength": 1 },
        "avoid": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "active_commitments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["description", "status"],
        "additionalProperties": false,
        "properties": {
          "description": { "type": "string", "minLength": 1 },
          "due_date": {
            "oneOf": [
              { "type": "string", "format": "date-time" },
              { "type": "null" }
            ]
          },
          "status": {
            "type": "string",
            "enum": ["active", "completed", "dropped"]
          }
        }
      }
    },
    "active_project_context": {
      "oneOf": [
        {
          "type": "object",
          "description": "Single active project (backward compatible)",
          "required": ["project_name", "status", "priority", "current_phase", "last_touched_at"],
          "additionalProperties": false,
          "properties": {
            "project_name": { "type": "string", "minLength": 1 },
            "status": { "type": "string", "enum": ["active", "paused", "completed"] },
            "priority": { "type": "integer", "minimum": 1 },
            "current_phase": { "type": "string" },
            "last_touched_at": { "type": "string", "format": "date-time" }
          }
        },
        {
          "type": "array",
          "description": "Multiple active projects, sorted by priority (1 = highest)",
          "items": {
            "type": "object",
            "required": ["project_name", "status", "priority", "current_phase", "last_touched_at"],
            "additionalProperties": false,
            "properties": {
              "project_name": { "type": "string", "minLength": 1 },
              "status": { "type": "string", "enum": ["active", "paused", "completed"] },
              "priority": { "type": "integer", "minimum": 1 },
              "current_phase": { "type": "string" },
              "last_touched_at": { "type": "string", "format": "date-time" }
            }
          }
        }
      ]
    },
    "canonical_business_facts": {
      "type": "object",
      "required": ["target_audience", "primary_platform", "location"],
      "properties": {
        "target_audience": { "type": "string", "minLength": 1 },
        "primary_platform": { "type": "string", "minLength": 1 },
        "location": { "type": "string" },
        "custom": {
          "type": "object",
          "description": "Flexible key-value store for IRIS-specific business facts."
        }
      }
    },
    "iris_voice_profile": {
      "type": "object",
      "description": "How Iris talks to this specific user. Defines a single personality, seeded by personality-calibration skill. Context-mode flex (gentle/steady/direct) happens at runtime from message signals, not from this profile.",
      "additionalProperties": false,
      "properties": {
        "warmth": { "type": "string", "enum": ["warm", "neutral", "reserved"] },
        "directness_ceiling": { "type": "string", "enum": ["soft", "moderate", "blunt"] },
        "humor": { "type": "string", "enum": ["dry", "playful", "sarcastic", "minimal", "unknown"] },
        "swearing_ok": { "type": "boolean" },
        "win_acknowledgment": { "type": "string", "enum": ["named_directly", "quietly_noted", "situational"] },
        "decision_style": { "type": "string", "enum": ["needs_time", "acts_fast", "situational", "unknown"] },
        "slip_handling": { "type": "string", "enum": ["name_it", "leave_alone", "situational"] },
        "motivators": { "type": "array", "items": { "type": "string" } },
        "shutdowns": { "type": "array", "items": { "type": "string" } },
        "mode_triggers": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "gentle": { "type": "array", "items": { "type": "string" } },
            "direct": { "type": "array", "items": { "type": "string" } }
          }
        },
        "assessments": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "string" },
        "calibration_progress": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "setup_complete": { "type": "boolean" },
            "pending_observations": { "type": "array", "items": { "type": "string" } },
            "first_conversation_at": { "oneOf": [{ "type": "string", "format": "date-time" }, { "type": "null" }] },
            "conversation_count": { "type": "integer", "minimum": 0 }
          }
        },
        "last_calibrated_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
