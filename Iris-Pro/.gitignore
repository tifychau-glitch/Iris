# Secrets
.env
credentials.json
token.json

# First-run marker (created by launcher)
.iris-installed

# Runtime data
data/*.db
data/*.sqlite

# Session logs (personal)
memory/logs/*
!memory/logs/.gitkeep

# Scratch work
.tmp/*
!.tmp/.gitkeep

# Claude Code local settings (personal hooks + permissions)
.claude/settings.local.json

# OS files
.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Auto-capture markers and logs
data/capture_markers/
data/auto_capture.log

# Personal user data — stays on personal branch only, not in template
memory/core-state.json
memory/MEMORY.md
memory/audit-log.jsonl
memory/ingest-log.jsonl
memory/pending-writes.jsonl
memory/wiki/
context/my-business.md
context/my-mteverest.md
context/my-voice.md
