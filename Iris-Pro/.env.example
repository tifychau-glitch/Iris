# Iris — Environment Variables
# Copy this file to .env and fill in your keys.

# ============================================================
# REQUIRED — Iris needs these three to work
# ============================================================

# Your Anthropic API key (for Iris to think)
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Telegram bot token (so Iris can reach you)
# Create a bot via @BotFather in Telegram
TELEGRAM_BOT_TOKEN=

# Pinecone API key (for long-term memory)
# Sign up free at: https://www.pinecone.io/
PINECONE_API_KEY=

# OpenAI API key (used by mem0 for embeddings)
# Get one at: https://platform.openai.com/
OPENAI_API_KEY=

# Your name (used as memory user ID)
MEM0_USER_ID=your_name

# ============================================================
# OPTIONAL — Unlock additional capabilities
# ============================================================

# Better research (Perplexity MCP)
# PERPLEXITY_API_KEY=

# Notion integration (MCP)
# NOTION_TOKEN=

# Gmail API (see docs/UPGRADE-PATHS.md)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Slack notifications
# SLACK_BOT_TOKEN=
# SLACK_CHANNEL_ID=

# Gamma API (slide generation)
# GAMMA_API_KEY=
