# Iris — Environment Variables
# IRIS will walk you through setting these up during your first conversation.
# You don't need to fill anything in manually.

# ============================================================
# AI PROVIDER — Choose your reasoning backend
# ============================================================
# Which provider Python scripts use (claude-cli | anthropic | openai | google)
# Default is claude-cli (uses your Claude Code subscription, no API key needed)
# AI_PROVIDER=claude-cli

# Anthropic API key (not needed if using claude-cli)
# ANTHROPIC_API_KEY=

# Google Gemini API key (only if AI_PROVIDER=google)
# GEMINI_API_KEY=

# ============================================================
# CORE — IRIS will help you set these up
# ============================================================

# Telegram bot token (so IRIS can reach you outside this window)
TELEGRAM_BOT_TOKEN=

# Your Telegram numeric user ID (message @userinfobot to get it)
# Required for the bot to accept your messages and send you check-ins
TELEGRAM_USER_ID=

# Telegram chat ID for automated messages (same as user ID for direct messages)
# Used by accountability check-ins, ghost detector, end-of-day summaries
TELEGRAM_CHAT_ID=

# Obsidian Vault — your second brain. Leave blank to use the default
# (~/Documents/Iris Vault). IRIS will scaffold the starter structure for you
# on first Test from the dashboard Settings page.
IRIS_VAULT_PATH=

# Upstash Vector (for long-term memory — free tier works)
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=

# OpenAI API key (powers memory embeddings — also used if AI_PROVIDER=openai)
OPENAI_API_KEY=

# Your name (used as memory user ID)
MEM0_USER_ID=

# Gmail SMTP (for email features)
SMTP_USER=
SMTP_PASSWORD=

# ============================================================
# OPTIONAL — Unlock additional capabilities
# ============================================================

# Better research (Perplexity MCP)
# PERPLEXITY_API_KEY=

# Notion integration (MCP)
# NOTION_TOKEN=

# Gmail API (see docs/UPGRADE-PATHS.md)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Slack notifications
# SLACK_BOT_TOKEN=
# SLACK_CHANNEL_ID=

# Gamma API (slide generation)
# GAMMA_API_KEY=
